# === Sybil Swarm — BYOK Configuration ===
# Provide at least ONE LLM API key

# OpenAI (GPT-4o-mini for bulk, GPT-4o for expert)
OPENAI_API_KEY=sk-...

# Anthropic (Haiku for bulk, Opus for expert)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini Flash for bulk, Gemini Pro for expert)
GOOGLE_API_KEY=AI...

# === Model Configuration ===
# Cheap model for 990 bulk agents (default: gpt-4o-mini)
BULK_MODEL=gpt-4o-mini

# Expert model for 10 deep-analysis agents (default: gpt-4o)
EXPERT_MODEL=gpt-4o

# Synthesis model for final report (default: gpt-4o)
SYNTHESIS_MODEL=gpt-4o

# === Server ===
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=sqlite:///./sybil-swarm.db

# === Simulation Defaults ===
MAX_CONCURRENT_AGENTS=50
TOTAL_AGENTS=1000
EXPERT_AGENTS=10
