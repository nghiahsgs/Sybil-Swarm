# === Sybil Swarm — BYOK Configuration ===
# Provide at least ONE LLM provider

# === Option 1: Alibaba Qwen (FREE — 1M tokens per model) ===
# Sign up: https://modelstudio.alibabacloud.com/
OPENAI_API_KEY=sk-your-dashscope-key
OPENAI_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
BULK_MODEL=openai/qwen-plus
EXPERT_MODEL=openai/qwen-max
SYNTHESIS_MODEL=openai/qwen-max

# === Option 2: OpenAI ===
# OPENAI_API_KEY=sk-...
# BULK_MODEL=gpt-4o-mini
# EXPERT_MODEL=gpt-4o
# SYNTHESIS_MODEL=gpt-4o

# === Option 3: Anthropic ===
# ANTHROPIC_API_KEY=sk-ant-...
# BULK_MODEL=claude-haiku-4-5-20251001
# EXPERT_MODEL=claude-sonnet-4-6
# SYNTHESIS_MODEL=claude-sonnet-4-6

# === Option 4: Google Gemini ===
# GOOGLE_API_KEY=AI...
# BULK_MODEL=gemini/gemini-2.0-flash
# EXPERT_MODEL=gemini/gemini-2.5-pro
# SYNTHESIS_MODEL=gemini/gemini-2.5-pro

# === Option 5: Custom OpenAI-compatible proxy ===
# OPENAI_API_KEY=sk-placeholder
# OPENAI_API_BASE=http://your-proxy:3456/v1
# BULK_MODEL=openai/your-model
# EXPERT_MODEL=openai/your-model
# SYNTHESIS_MODEL=openai/your-model

# === Server ===
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_URL=sqlite:///./sybil-swarm.db

# === Simulation Defaults ===
MAX_CONCURRENT_AGENTS=10
TOTAL_AGENTS=10
EXPERT_AGENTS=2
